{
  "name": "ben-mathu",
  "version": "4.2.1",
  "engines": {
    "node": ">=18.19",
    "npm": "10.7.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --prod",
    "start:dev": "nodemon -x 'sh ./icons/serialize.sh && ng serve'",
    "build": "ng build --configuration production --base-href=https://ben-mathu.github.io/ben-mathu/",
    "watch": "ng build --watch --configuration development",
    "deploy": "npx angular-cli-ghpages --dir=dist/ben-mathu/browser --no-silent",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "^19.2.17",
    "@angular/animations": "^19.2.15",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.15",
    "@angular/compiler": "^19.2.15",
    "@angular/core": "^19.2.15",
    "@angular/fire": "^19.2.0",
    "@angular/forms": "^19.2.15",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.15",
    "@angular/platform-browser-dynamic": "^19.2.15",
    "@angular/router": "^19.2.15",
    "@github/markdown-toolbar-element": "^2.2.1",
    "jquery": "^3.6.0",
    "marked": "^15.0.0",
    "ngx-markdown": "^19",
    "rxjs": "^7.4.0",
    "tslib": "^2.3.0",
    "xng-breadcrumb": "^14.0.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/cli": "^19.2.17",
    "@angular/compiler-cli": "^19.2.15",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^18",
    "angular-cli-ghpages": "^2.0.1",
    "dotenv": "^16.0.3",
    "jasmine-core": "~3.10.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "nodemon": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.5.4",
    "yargs": "^17.7.1"
  }
}
