{
  "name": "ben-mathu",
  "version": "5.0.1",
  "engines": {
    "node": ">=18.19",
    "npm": "10.7.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "ng serve --prod",
    "start:dev": "nodemon -x 'sh ./icons/serialize.sh && ng serve'",
    "build": "ng build --configuration production --base-href=https://ben-mathu.github.io/ben-mathu/",
    "watch": "ng build --watch --configuration development",
    "deploy": "npx angular-cli-ghpages --dir=dist/ben-mathu/browser --no-silent",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.14",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.14",
    "@angular/compiler": "^20.3.14",
    "@angular/core": "^20.3.14",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.3.14",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^20.3.14",
    "@angular/platform-browser-dynamic": "^20.3.14",
    "@angular/router": "^20.3.14",
    "@github/markdown-toolbar-element": "^2.2.1",
    "jquery": "^3.6.0",
    "marked": "^15.0.0",
    "ngx-markdown": "^20",
    "rxjs": "^7.4.0",
    "tslib": "^2.3.0",
    "xng-breadcrumb": "^14.0.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.12",
    "@angular/cli": "^20.3.12",
    "@angular/compiler-cli": "^20.3.14",
    "@types/jasmine": "~3.10.0",
    "@types/node": "^20",
    "angular-cli-ghpages": "^2.0.1",
    "dotenv": "^16.0.3",
    "jasmine-core": "~3.10.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.1.0",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "~1.7.0",
    "nodemon": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "typescript": "~5.9.3",
    "yargs": "^17.7.1"
  }
}